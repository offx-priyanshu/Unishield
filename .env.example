# ============================================================
#   SNOX - Smart AI-Based Student Outpass & Security System
#   Environment Configuration — EXAMPLE FILE
#   Copy this file to .env and fill in your actual values.
#   Run: cp .env.example .env
# ============================================================


# ── Flask App ────────────────────────────────────────────────
SECRET_KEY=your-flask-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=1


# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///snox.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/snox_db


# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here


# ── Fast2SMS API (Primary SMS Provider) ──────────────────────
# Get your key from: https://www.fast2sms.com/
FAST2SMS_API_KEY=your_fast2sms_api_key


# ── Twilio API (Fallback SMS Provider) ───────────────────────
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+91XXXXXXXXXX


# ── Admin Default Credentials ────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123


# ── Face Recognition Settings ────────────────────────────────
FACE_TOLERANCE=0.5


# ── App Security Settings ────────────────────────────────────
SESSION_TIMEOUT=30
VIOLATION_THRESHOLD=3
